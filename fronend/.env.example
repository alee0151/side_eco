# ─── EcoTrace Frontend environment ────────────────────────────────────────────
#
# Copy this file to .env (git-ignored) and fill in the values.
#
# During local development leave VITE_API_BASE_URL empty — the Vite dev server
# proxy in vite.config.ts will forward /api/* → http://127.0.0.1:8000.
#
# For production deployments set VITE_API_BASE_URL to the deployed backend URL,
# e.g. https://api.ecotrace.example.com
#
VITE_API_BASE_URL=
