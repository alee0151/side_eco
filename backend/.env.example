DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecotrace
DB_USER=postgres
DB_PASSWORD=123456

# ABN Lookup API
ABR_GUID=22576142-644e-41c3-b366-1524ed25a0dd

# ================================================================
# Australian Trade Mark Search API  —  IP Australia
#
# Fixed split:
#   OAuth token fetch  →  TEST environment
#     POST https://test.api.ipaustralia.gov.au/public/external-token-api/v1/access_token
#     grant_type=client_credentials  (body params)
#
#   Quick search + trademark detail  →  PRODUCTION environment
#     https://production.api.ipaustralia.gov.au/public/australian-trade-mark-search-api/v1
#
# Get credentials: https://api.ipaustralia.gov.au/
#   Sign in -> My Apps -> Subscribe to Trade Mark Search API (Sandbox)
#   Copy the generated Client ID and Client Secret below.
# ================================================================

IP_AUSTRALIA_CLIENT_ID=your_client_id
IP_AUSTRALIA_CLIENT_SECRET=your_client_secret

# Optional URL overrides (leave blank to use the built-in defaults above)
IP_AUSTRALIA_TOKEN_URL=
IP_AUSTRALIA_TRADEMARK_URL=
