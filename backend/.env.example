DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecotrace
DB_USER=postgres
DB_PASSWORD=123456

# ABN Lookup API
ABR_GUID=22576142-644e-41c3-b366-1524ed25a0dd

# ================================================================
# Australian Trade Mark Search API  —  IP Australia
#
# TEST and PRODUCTION use SEPARATE app subscriptions on the
# IP Australia developer portal (api.ipaustralia.gov.au).
# You must subscribe to the Trade Mark Search API twice — once
# under the Sandbox environment and once under Production —
# and generate a separate client_id / client_secret for each.
#
# Portal: https://api.ipaustralia.gov.au/
#   Sandbox  subscription -> copy id/secret below as TEST_*
#   Production subscription -> copy id/secret below as PROD_*
# ================================================================

# --- TEST environment credentials (Sandbox subscription) ---
IP_AUSTRALIA_TEST_CLIENT_ID=your_test_client_id
IP_AUSTRALIA_TEST_CLIENT_SECRET=your_test_client_secret

# --- PRODUCTION environment credentials (Production subscription) ---
IP_AUSTRALIA_PROD_CLIENT_ID=your_prod_client_id
IP_AUSTRALIA_PROD_CLIENT_SECRET=your_prod_client_secret

# ----------------------------------------------------------------
# Active environment selection
#
# Set IP_AUSTRALIA_ENV to 'test' or 'production'.
# The matching credential pair above will be used automatically.
#   test       -> TEST_CLIENT_ID / TEST_CLIENT_SECRET + test token URL
#   production -> PROD_CLIENT_ID / PROD_CLIENT_SECRET + prod token URL
# ----------------------------------------------------------------
IP_AUSTRALIA_ENV=test

# Override URLs only if IP Australia changes their endpoints.
# Leave blank to use the built-in defaults for the selected environment.
IP_AUSTRALIA_TOKEN_URL=
IP_AUSTRALIA_TRADEMARK_URL=
