DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecotrace
DB_USER=postgres
DB_PASSWORD=123456

# ABN Lookup API
ABR_GUID=22576142-644e-41c3-b366-1524ed25a0dd

# ================================================================
# Australian Trade Mark Search API  —  IP Australia
#
# FIXED split (confirmed):
#   OAuth token fetch  →  TEST  environment  (test.api.ipaustralia.gov.au)
#   Quick search + trademark detail  →  PRODUCTION  (production.api.ipaustralia.gov.au)
#
# Only the TEST subscription credentials are required.
# Get them from: https://api.ipaustralia.gov.au/
#   1. Sign in -> My Apps -> Subscribe to Trade Mark Search API (Sandbox)
#   2. Copy the generated Client ID and Client Secret below.
# ================================================================

IP_AUSTRALIA_TEST_CLIENT_ID=your_test_client_id
IP_AUSTRALIA_TEST_CLIENT_SECRET=your_test_client_secret

# ----------------------------------------------------------------
# Optional URL overrides  —  leave BLANK to use the built-in defaults.
#
# Default token URL    : https://test.api.ipaustralia.gov.au/public/external-token-api/v1/access_token
# Default trademark URL: https://production.api.ipaustralia.gov.au/public/australian-trade-mark-search-api/v1
# ----------------------------------------------------------------
IP_AUSTRALIA_TOKEN_URL=
IP_AUSTRALIA_TRADEMARK_URL=
