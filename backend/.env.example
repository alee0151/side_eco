DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecotrace
DB_USER=postgres
DB_PASSWORD=123456

# ABN Lookup API
ABR_GUID=22576142-644e-41c3-b366-1524ed25a0dd

# ---------------------------------------------------------------
# Australian Trade Mark Search API
#
# IMPORTANT: TOKEN_URL and TRADEMARK_URL must be on the SAME
# environment.  Mixing test token with production API (or vice
# versa) will return HTTP 401 / 403 on every trademark request.
#
# Choose ONE block below and uncomment it.
# ---------------------------------------------------------------

# --- TEST environment (use with test credentials) ---
IP_AUSTRALIA_CLIENT_ID=your_test_client_id
IP_AUSTRALIA_CLIENT_SECRET=your_test_client_secret
IP_AUSTRALIA_TOKEN_URL=https://test.api.ipaustralia.gov.au/public/external-token-api/v1/access_token
IP_AUSTRALIA_TRADEMARK_URL=https://test.api.ipaustralia.gov.au/public/australian-trade-mark-search-api/v1

# --- PRODUCTION environment (use with production credentials) ---
# IP_AUSTRALIA_CLIENT_ID=your_production_client_id
# IP_AUSTRALIA_CLIENT_SECRET=your_production_client_secret
# IP_AUSTRALIA_TOKEN_URL=https://production.api.ipaustralia.gov.au/public/external-token-api/v1/access_token
# IP_AUSTRALIA_TRADEMARK_URL=https://production.api.ipaustralia.gov.au/public/australian-trade-mark-search-api/v1
