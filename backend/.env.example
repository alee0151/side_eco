# ABN Lookup API
ABR_GUID=22576142-644e-41c3-b366-1524ed25a0dd

# ---------------------------------------------------------------
# Australian Trade Mark Search API  —  CONFIRMED URLs
#
# TOKEN_URL    : test environment  (https://test.api.ipaustralia.gov.au)
# TRADEMARK_URL: production API    (https://production.api.ipaustralia.gov.au)
#
# These are intentionally different environments as confirmed.
# Replace client_id / client_secret with your actual credentials.
# ---------------------------------------------------------------

IP_AUSTRALIA_CLIENT_ID=your_client_id
IP_AUSTRALIA_CLIENT_SECRET=your_client_secret

# OAuth token endpoint  — TEST instance
IP_AUSTRALIA_TOKEN_URL=https://test.api.ipaustralia.gov.au/public/external-token-api/v1/access_token

# Trade Mark Search API — PRODUCTION instance
IP_AUSTRALIA_TRADEMARK_URL=https://production.api.ipaustralia.gov.au/public/australian-trade-mark-search-api/v1
